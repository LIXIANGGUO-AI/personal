# ============================================
# .env.example — 复制为 .env.local，填入真实值
# ============================================

# Notion 集成 Secret（在 notion.so/my-integrations 创建）
NOTION_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 数据库 ID（从数据库 URL 中复制）
# URL 格式: https://notion.so/your-workspace/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
